#!/usr/bin/env bash
# gsd-sdk shim — workaround for gsd-build/get-shit-done#2414 (#2393, #2423).
#
# @gsd-build/sdk@0.1.0 only exposes `run | auto | init`, but all v1.37+ skills
# call `gsd-sdk query <namespace>.<action> [args]`. The binary that actually
# implements those handlers — `gsd-tools.cjs` — ships with get-shit-done-cc
# but is never linked to PATH.
#
# This shim sits on PATH ahead of the real @gsd-build/sdk binary and:
#   - routes `gsd-sdk query X.Y [args]` → `node gsd-tools.cjs X Y [args]`
#   - routes `gsd-sdk query X   [args]` → `node gsd-tools.cjs X   [args]`
#   - passes every other invocation through to the real @gsd-build/sdk binary
#
# Remove this shim (`rm "$0"`) if/when upstream closes #2414.

set -euo pipefail

GSD_TOOLS="$HOME/.claude/get-shit-done/bin/gsd-tools.cjs"

# Locate the real @gsd-build/sdk binary — skip ourselves to avoid recursion.
self_real=$(/usr/bin/readlink -f "$0" 2>/dev/null || echo "$0")
REAL_SDK=""
npm_prefix=$(npm prefix -g 2>/dev/null || true)
if [ -n "$npm_prefix" ] && [ -x "$npm_prefix/bin/gsd-sdk" ]; then
    cand_real=$(/usr/bin/readlink -f "$npm_prefix/bin/gsd-sdk" 2>/dev/null || echo "$npm_prefix/bin/gsd-sdk")
    [ "$cand_real" != "$self_real" ] && REAL_SDK="$npm_prefix/bin/gsd-sdk"
fi
if [ -z "$REAL_SDK" ]; then
    IFS=':' read -r -a _path_parts <<< "$PATH"
    for d in "${_path_parts[@]}"; do
        cand="$d/gsd-sdk"
        [ -x "$cand" ] || continue
        cand_real=$(/usr/bin/readlink -f "$cand" 2>/dev/null || echo "$cand")
        if [ "$cand_real" != "$self_real" ]; then
            REAL_SDK="$cand"
            break
        fi
    done
fi

if [ "${1:-}" = "query" ]; then
    shift
    if [ $# -eq 0 ]; then
        echo "gsd-sdk query: missing command" >&2
        exit 2
    fi
    cmd="$1"; shift
    if [[ "$cmd" == *.* ]]; then
        top="${cmd%%.*}"
        sub="${cmd#*.}"
        exec node "$GSD_TOOLS" "$top" "$sub" "$@"
    else
        exec node "$GSD_TOOLS" "$cmd" "$@"
    fi
fi

if [ -n "$REAL_SDK" ]; then
    exec "$REAL_SDK" "$@"
fi

cat >&2 <<'EOF'
gsd-sdk shim: no `run | auto | init` binary found on PATH.

Install the real @gsd-build/sdk package, or remove this shim:
  npm i -g @gsd-build/sdk
EOF
exit 127
